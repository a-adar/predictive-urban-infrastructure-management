<configuration>
    <input>
        <net-file value="../network/chicago.net.xml"/>
        <route-files value="../routes/chicago_incident.rou.xml"/>
    </input>

    <time>
        <begin value="0"/>
        <end value="3600"/>
    </time>

    <output>
        <tripinfo-output value="../../results/tripinfo_incident_ai.xml"/>
        <edgedata-output value="../../results/edge_data_incident_ai.xml"/>
    </output>
</configuration>